                                {
                                  "type": "text",
                                  "id": "pcI5s",
                                  "name": "prdBodyA",
                                  "fill": "#444444",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "## Problem\nPodcast players optimize playback speed and discovery, but they rarely deliver trustworthy semantic skipping. Users still waste minutes on repetitive segments while creators lack clear controls around how automation is applied.",
                                  "lineHeight": 1.8,
                                  "fontFamily": "Inter",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
                                  "id": "WL78F",
                                  "name": "prdBodyB",
                                  "fill": "#444444",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "## Goals\n- Remove low-value listening time without breaking trust.\n- Surface confidence so users can review edits before playback.\n- Keep the workflow simple enough for founder-led setup and testing.\n- Preserve privacy with opt-in and transparent processing choices.",
                                  "lineHeight": 1.8,
                                  "fontFamily": "Inter",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
                                  "id": "QEpUm",
                                  "name": "prdBodyC",
                                  "fill": "#444444",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "## Requirements\n1. Import and analyze episodes quickly.\n2. Detect ads, intros, and filler with editable confidence.\n3. Preview the cleaned timeline before export or playback.\n4. Store user choices and creator-safe defaults.\n5. Report minutes saved and review outcomes for iteration.",
                                  "lineHeight": 1.8,
                                  "fontFamily": "Inter",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                },
                                {
                                  "type": "text",
                                  "id": "L31b6",
                                  "name": "prdBodyD",
                                  "fill": "#444444",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "## Success Metrics\n- Time-to-first-cleaned-episode under 5 minutes\n- Clear confidence review for every detected segment\n- Repeat usage driven by measurable time saved\n- Early creator and listener trust signals stay positive",
                                  "lineHeight": 1.8,
                                  "fontFamily": "Inter",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                }
                              ]
                            }
