                                              "alignItems": "center",
                                              "children": [
                                                {
                                                  "type": "text",
                                                  "id": "SpMbC",
                                                  "name": "exportTxt",
                                                  "fill": "#FFFFFF",
                                                  "content": "Export Report",
                                                  "fontFamily": "Space Grotesk",
