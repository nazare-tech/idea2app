                                          "content": "MARKET INTELLIGENCE",
                                          "fontFamily": "Inter",
                                          "fontSize": 11,
                                          "fontWeight": "500",
                                          "letterSpacing": 1.2
                                        },
                                        {
                                          "type": "text",
                                          "id": "mgqS9",
                                          "name": "mainTitle",
                                          "fill": "#0A0A0A",
                                          "content": "PRD",
                                          "fontFamily": "Space Grotesk",
                                          "fontSize": 48,
                                          "fontWeight": "700",
                                          "letterSpacing": -2
                                        },
                                        {
                                          "type": "text",
                                          "id": "QsA1m",
                                          "name": "subTitle",
                                          "fill": "#666666",
                                          "content": "PodPacer helps listeners reclaim time by detecting ads, intros, and filler with semantic confidence scoring and creator-aware controls.",
                                          "fontFamily": "Inter",
                                          "fontSize": 14,
                                          "fontWeight": "normal"
                                        }
                                      ]
                                    },
                                    {
                                      "type": "frame",
                                      "id": "CbfMd",
