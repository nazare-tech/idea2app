                                        },
                                        {
                                          "type": "text",
                                          "id": "C1fjv",
                                          "name": "paragraph",
                                          "fill": "#444444",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "The travel industry has experienced significant shifts toward authentic, experiential travel, with 76% of millennials preferring to spend money on experiences rather than material goods. However, the current digital travel ecosystem remains dominated by platforms that prioritize mainstream tourist attractions and commercially bookable experiences. This has created a substantial market gap for travelers seeking genuine local immersion.",
                                          "lineHeight": 1.6,
                                          "fontFamily": "Inter",
                                          "fontSize": 13,
                                          "fontWeight": "normal"
                                        },
                                        {
                                          "type": "text",
                                          "id": "nzkAT",
                                          "name": "paragraph",
                                          "fill": "#444444",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "The rise of solo travel, accounting for 25% of all trips globally, combined with increased comfort with mobile-first platforms, creates room for a differentiated approach. Current market leaders like Wanderlog, Viator, and GetYourGuide excel at logistics and popular attractions but fail to surface the hyperlocal, non-commercialized experiences that define authentic cultural immersion.",
                                          "lineHeight": 1.6,
                                          "fontFamily": "Inter",
                                          "fontSize": 13,
                                          "fontWeight": "normal"
                                        },
                                        {
                                          "type": "text",
                                          "id": "hjEuu",
                                          "name": "paragraph",
                                          "fill": "#444444",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "LocalLens positions itself at the intersection of community-driven content curation and personalized travel planning, leveraging the creator economy and local expertise to solve a persistent pain point in independent travel.",
                                          "lineHeight": 1.6,
                                          "fontFamily": "Inter",
                                          "fontSize": 13,
                                          "fontWeight": "normal"
                                        }
                                      ]
                                    },
                                    {
                                      "type": "frame",
                                      "id": "nJiBb",
                                      "name": "1.2 Problem Definition / User Needs",
                                      "width": "fill_container",
                                      "layout": "vertical",
                                      "gap": 10,
                                      "children": [
                                        {
                                          "type": "text",
                                          "id": "p0NlB",
                                          "name": "h3 Problem Definition",
                                          "fill": "#0A0A0A",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "1.2 Problem Definition / User Needs",
                                          "lineHeight": 1.2,
                                          "fontFamily": "Space Grotesk",
                                          "fontSize": 20,
                                          "fontWeight": "600"
                                        },
                                        {
                                          "type": "text",
                                          "id": "zBwbi",
                                          "name": "strong Primary Problems",
                                          "fill": "#0A0A0A",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "Primary Problems Identified",
                                          "lineHeight": 1.4,
                                          "fontFamily": "Inter",
                                          "fontSize": 13,
                                          "fontWeight": "700"
                                        },
                                        {
                                          "type": "frame",
                                          "id": "iF00A",
                                          "name": "Primary problems list",
                                          "width": "fill_container",
                                          "layout": "vertical",
                                          "gap": 6,
                                          "children": [
                                            {
                                              "type": "text",
                                              "id": "y9R1l",
                                              "name": "bullet",
                                              "fill": "#444444",
                                              "textGrowth": "fixed-width",
                                              "width": "fill_container",
                                              "content": "• Solo travelers still end up at overcrowded tourist attractions despite seeking authentic experiences.",
                                              "lineHeight": 1.45,
                                              "fontFamily": "Inter",
                                              "fontSize": 13,
                                              "fontWeight": "normal"
                                            },
                                            {
                                              "type": "text",
                                              "id": "2AaIs",
                                              "name": "bullet",
                                              "fill": "#444444",
                                              "textGrowth": "fixed-width",
                                              "width": "fill_container",
                                              "content": "• Existing platforms are biased toward mainstream, bookable activities.",
                                              "lineHeight": 1.45,
                                              "fontFamily": "Inter",
                                              "fontSize": 13,
                                              "fontWeight": "normal"
                                            },
                                            {
                                              "type": "text",
                                              "id": "JjZdH",
                                              "name": "bullet",
                                              "fill": "#444444",
                                              "textGrowth": "fixed-width",
                                              "width": "fill_container",
                                              "content": "• Verified locals-only trust signals are weak or missing.",
                                              "lineHeight": 1.45,
                                              "fontFamily": "Inter",
                                              "fontSize": 13,
                                              "fontWeight": "normal"
                                            },
                                            {
                                              "type": "text",
                                              "id": "HA8y4",
                                              "name": "bullet",
                                              "fill": "#444444",
                                              "textGrowth": "fixed-width",
                                              "width": "fill_container",
                                              "content": "• Micro, non-bookable experiences like neighborhood bars, street markets, and community events are underrepresented.",
                                              "lineHeight": 1.45,
                                              "fontFamily": "Inter",
                                              "fontSize": 13,
                                              "fontWeight": "normal"
                                            },
                                            {
                                              "type": "text",
                                              "id": "X7oct",
                                              "name": "bullet",
                                              "fill": "#444444",
                                              "textGrowth": "fixed-width",
                                              "width": "fill_container",
                                              "content": "• Neighborhood-first discovery, hyperlocal granularity, and contextual guidance are all weak.",
                                              "lineHeight": 1.45,
                                              "fontFamily": "Inter",
                                              "fontSize": 13,
                                              "fontWeight": "normal"
                                            }
                                          ]
                                        },
                                        {
                                          "type": "text",
                                          "id": "770ra",
                                          "name": "strong Unmet User Needs",
                                          "fill": "#0A0A0A",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "Unmet User Needs",
                                          "lineHeight": 1.4,
                                          "fontFamily": "Inter",
                                          "fontSize": 13,
                                          "fontWeight": "700"
                                        },
                                        {
                                          "type": "frame",
                                          "id": "ADBR9",
                                          "name": "Unmet user needs list",
                                          "width": "fill_container",
                                          "layout": "vertical",
                                          "gap": 6,
                                          "children": [
                                            {
                                              "type": "text",
                                              "id": "qPzjG",
                                              "name": "bullet",
                                              "fill": "#444444",
                                              "textGrowth": "fixed-width",
                                              "width": "fill_container",
                                              "content": "• Access to vetted local knowledge beyond guidebooks",
                                              "lineHeight": 1.45,
                                              "fontFamily": "Inter",
                                              "fontSize": 13,
                                              "fontWeight": "normal"
                                            },
                                            {
                                              "type": "text",
                                              "id": "5uoV4",
                                              "name": "bullet",
                                              "fill": "#444444",
                                              "textGrowth": "fixed-width",
                                              "width": "fill_container",
                                              "content": "• Curated itineraries featuring experiences locals actually enjoy",
                                              "lineHeight": 1.45,
                                              "fontFamily": "Inter",
                                              "fontSize": 13,
                                              "fontWeight": "normal"
                                            },
                                            {
                                              "type": "text",
                                              "id": "OyJlo",
                                              "name": "bullet",
                                              "fill": "#444444",
                                              "textGrowth": "fixed-width",
                                              "width": "fill_container",
                                              "content": "• Neighborhood-level discovery with walking and transit optimized routes",
                                              "lineHeight": 1.45,
                                              "fontFamily": "Inter",
                                              "fontSize": 13,
                                              "fontWeight": "normal"
                                            },
                                            {
                                              "type": "text",
                                              "id": "bSIJx",
                                              "name": "bullet",
                                              "fill": "#444444",
                                              "textGrowth": "fixed-width",
                                              "width": "fill_container",
                                              "content": "• Cultural context, etiquette guidance, and seasonal recommendations",
                                              "lineHeight": 1.45,
                                              "fontFamily": "Inter",
                                              "fontSize": 13,
                                              "fontWeight": "normal"
                                            }
                                          ]
                                        },
                                        {
                                          "type": "text",
                                          "id": "hGz7s",
                                          "name": "strong Representative Personas",
                                          "fill": "#0A0A0A",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "Representative Personas",
                                          "lineHeight": 1.4,
                                          "fontFamily": "Inter",
                                          "fontSize": 13,
                                          "fontWeight": "700"
                                        },
                                        {
                                          "type": "text",
                                          "id": "lF36G",
                                          "name": "paragraph",
                                          "fill": "#444444",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "The document covers solo travelers seeking authentic trips, efficient weekend explorers who want insider guidance, and budget-conscious sabbatical travelers who need confidence, meaning, and affordability.",
                                          "lineHeight": 1.6,
                                          "fontFamily": "Inter",
                                          "fontSize": 13,
                                          "fontWeight": "normal"
                                        }
                                      ]
                                    }
                                  ]
                                },
                                {
                                  "type": "frame",
                                  "id": "c6WAr",
                                  "name": "Section IV Features and Functionality",
                                  "width": "fill_container",
                                  "layout": "vertical",
                                  "gap": 14,
                                  "children": [
                                    {
                                      "type": "text",
                                      "id": "MASED",
                                      "name": "h2 Features",
                                      "fill": "#0A0A0A",
                                      "textGrowth": "fixed-width",
                                      "width": "fill_container",
                                      "content": "IV. Features and Functionality",
                                      "lineHeight": 1.05,
                                      "fontFamily": "Space Grotesk",
                                      "fontSize": 30,
                                      "fontWeight": "700"
                                    },
                                    {
                                      "type": "frame",
                                      "id": "qcQzS",
                                      "name": "4.1 Requirements",
                                      "width": "fill_container",
                                      "layout": "vertical",
                                      "gap": 10,
                                      "children": [
                                        {
                                          "type": "text",
                                          "id": "rNlJK",
                                          "name": "h3 Requirements",
                                          "fill": "#0A0A0A",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "4.1 Requirements",
                                          "lineHeight": 1.2,
                                          "fontFamily": "Space Grotesk",
                                          "fontSize": 20,
                                          "fontWeight": "600"
                                        },
                                        {
                                          "type": "text",
                                          "id": "ghpxP",
                                          "name": "strong Functional Requirements",
                                          "fill": "#0A0A0A",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "Functional Requirements",
                                          "lineHeight": 1.4,
                                          "fontFamily": "Inter",
                                          "fontSize": 13,
                                          "fontWeight": "700"
                                        },
                                        {
                                          "type": "text",
                                          "id": "os2SL",
                                          "name": "paragraph",
                                          "fill": "#444444",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "User registration and profile management, local curator onboarding and verification, custom itinerary generation, community recommendation submission and curation, one-time itinerary payments, ratings and reviews, messaging, offline map support, notifications, and admin moderation.",
                                          "lineHeight": 1.6,
                                          "fontFamily": "Inter",
                                          "fontSize": 13,
                                          "fontWeight": "normal"
                                        },
                                        {
                                          "type": "text",
                                          "id": "M68j6",
                                          "name": "strong Non-Functional Requirements",
                                          "fill": "#0A0A0A",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "Non-Functional Requirements",
                                          "lineHeight": 1.4,
                                          "fontFamily": "Inter",
                                          "fontSize": 13,
                                          "fontWeight": "700"
                                        },
                                        {
                                          "type": "text",
                                          "id": "YA9Jn",
                                          "name": "paragraph",
                                          "fill": "#444444",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "Page loads under 2 seconds, 99.9% uptime, secure payment handling, scalability to 10,000 concurrent users, mobile optimization, and WCAG 2.1 AA accessibility.",
                                          "lineHeight": 1.6,
                                          "fontFamily": "Inter",
                                          "fontSize": 13,
                                          "fontWeight": "normal"
                                        },
                                        {
                                          "type": "text",
                                          "id": "mDmJ0",
                                          "name": "strong Integration Requirements",
                                          "fill": "#0A0A0A",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "Integration Requirements",
                                          "lineHeight": 1.4,
                                          "fontFamily": "Inter",
                                          "fontSize": 13,
                                          "fontWeight": "700"
                                        },
                                        {
                                          "type": "text",
                                          "id": "TdD2G",
                                          "name": "paragraph",
                                          "fill": "#444444",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "Google Maps, Stripe, SendGrid, analytics tooling, and content management for curator-generated content.",
                                          "lineHeight": 1.6,
                                          "fontFamily": "Inter",
                                          "fontSize": 13,
                                          "fontWeight": "normal"
                                        }
                                      ]
                                    },
                                    {
                                      "type": "frame",
                                      "id": "Vblpx",
                                      "name": "4.2 User Stories / Use Cases",
                                      "width": "fill_container",
                                      "layout": "vertical",
                                      "gap": 10,
                                      "children": [
                                        {
                                          "type": "text",
                                          "id": "3VSzt",
                                          "name": "h3 User Stories",
                                          "fill": "#0A0A0A",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "4.2 User Stories / Use Cases",
                                          "lineHeight": 1.2,
                                          "fontFamily": "Space Grotesk",
                                          "fontSize": 20,
                                          "fontWeight": "600"
                                        },
                                        {
                                          "type": "frame",
                                          "id": "Zmnoz",
                                          "name": "numbered user stories",
                                          "width": "fill_container",
                                          "layout": "vertical",
                                          "gap": 6,
                                          "children": [
                                            {
                                              "type": "text",
                                              "id": "FbwgC",
                                              "name": "numbered item",
                                              "fill": "#444444",
                                              "textGrowth": "fixed-width",
                                              "width": "fill_container",
                                              "content": "1. Buy a custom itinerary and experience a city like a resident, not a tourist.",
                                              "lineHeight": 1.45,
                                              "fontFamily": "Inter",
                                              "fontSize": 13,
                                              "fontWeight": "normal"
                                            },
                                            {
                                              "type": "text",
                                              "id": "rxa27",
                                              "name": "numbered item",
                                              "fill": "#444444",
                                              "textGrowth": "fixed-width",
                                              "width": "fill_container",
                                              "content": "2. Contribute neighborhood recommendations as a resident and earn income.",
                                              "lineHeight": 1.45,
                                              "fontFamily": "Inter",
                                              "fontSize": 13,
                                              "fontWeight": "normal"
                                            },
                                            {
                                              "type": "text",
                                              "id": "fvUnP",
                                              "name": "numbered item",
                                              "fill": "#444444",
                                              "textGrowth": "fixed-width",
                                              "width": "fill_container",
                                              "content": "3. Discover local places that do not appear in guidebooks.",
                                              "lineHeight": 1.45,
                                              "fontFamily": "Inter",
                                              "fontSize": 13,
                                              "fontWeight": "normal"
                                            },
                                            {
                                              "type": "text",
                                              "id": "G8yGW",
                                              "name": "numbered item",
                                              "fill": "#444444",
                                              "textGrowth": "fixed-width",
                                              "width": "fill_container",
                                              "content": "4. Get etiquette, language, and cultural guidance for respectful travel.",
                                              "lineHeight": 1.45,
                                              "fontFamily": "Inter",
                                              "fontSize": 13,
                                              "fontWeight": "normal"
                                            },
                                            {
                                              "type": "text",
                                              "id": "6FFyh",
                                              "name": "numbered item",
                                              "fill": "#444444",
                                              "textGrowth": "fixed-width",
                                              "width": "fill_container",
                                              "content": "5. Validate recommendations as a local to keep authenticity standards high.",
                                              "lineHeight": 1.45,
                                              "fontFamily": "Inter",
                                              "fontSize": 13,
                                              "fontWeight": "normal"
                                            }
                                          ]
                                        }
                                      ]
                                    },
                                    {
                                      "type": "frame",
                                      "id": "siPie",
                                      "name": "4.3 Prioritization",
                                      "width": "fill_container",
                                      "layout": "vertical",
                                      "gap": 10,
                                      "children": [
                                        {
                                          "type": "text",
                                          "id": "E1BmC",
                                          "name": "h3 Prioritization",
                                          "fill": "#0A0A0A",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "4.3 Prioritization",
                                          "lineHeight": 1.2,
                                          "fontFamily": "Space Grotesk",
                                          "fontSize": 20,
                                          "fontWeight": "600"
                                        },
                                        {
                                          "type": "text",
                                          "id": "2Forg",
                                          "name": "priority P0",
                                          "fill": "#444444",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "Must-Have (P0): user registration, curator verification, core itinerary generation, payment processing, recommendation submission, Google Maps integration, responsive web UI, and core search and filtering.",
                                          "lineHeight": 1.6,
                                          "fontFamily": "Inter",
                                          "fontSize": 13,
                                          "fontWeight": "normal"
                                        },
                                        {
                                          "type": "text",
                                          "id": "YzCi8",
                                          "name": "priority P1",
                                          "fill": "#444444",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "Should-Have (P1): advanced personalization, messaging, community validation, offline downloads, cultural context, revenue-share dashboards, push notifications, and social sharing.",
                                          "lineHeight": 1.6,
                                          "fontFamily": "Inter",
                                          "fontSize": 13,
                                          "fontWeight": "normal"
                                        },
                                        {
                                          "type": "text",
                                          "id": "F9sz6",
                                          "name": "priority P2",
                                          "fill": "#444444",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "Nice-to-Have (P2): native mobile apps, AI recommendations, booking integrations, group planning, loyalty programs, curator certification, localization, and AR discovery.",
                                          "lineHeight": 1.6,
                                          "fontFamily": "Inter",
                                          "fontSize": 13,
                                          "fontWeight": "normal"
                                        }
                                      ]
                                    },
                                    {
                                      "type": "frame",
                                      "id": "cWCjQ",
                                      "name": "4.4 UI/UX Design Specifications",
                                      "width": "fill_container",
                                      "layout": "vertical",
                                      "gap": 10,
                                      "children": [
                                        {
                                          "type": "text",
                                          "id": "sxLlg",
                                          "name": "h3 UI UX",
                                          "fill": "#0A0A0A",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "4.4 UI/UX Design Specifications",
                                          "lineHeight": 1.2,
                                          "fontFamily": "Space Grotesk",
                                          "fontSize": 20,
                                          "fontWeight": "600"
                                        },
                                        {
                                          "type": "text",
                                          "id": "qqfRt",
                                          "name": "paragraph",
                                          "fill": "#444444",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "The PRD defines four main flows: onboarding, itinerary discovery, curator journey, and trip execution. Interface guidance is map-first, mobile-friendly, progressively disclosed, visually authentic, and trust-signal heavy. Accessibility requirements include screen-reader support, high contrast, text scaling to 200%, voice navigation support, and offline-friendly behavior.",
                                          "lineHeight": 1.6,
                                          "fontFamily": "Inter",
                                          "fontSize": 13,
                                          "fontWeight": "normal"
                                        }
                                      ]
                                    },
                                    {
                                      "type": "frame",
                                      "id": "26qan",
                                      "name": "4.5 Technical Requirements",
                                      "width": "fill_container",
                                      "layout": "vertical",
                                      "gap": 10,
                                      "children": [
                                        {
                                          "type": "text",
                                          "id": "8vh0z",
                                          "name": "h3 Technical Requirements",
                                          "fill": "#0A0A0A",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "4.5 Technical Requirements",
                                          "lineHeight": 1.2,
                                          "fontFamily": "Space Grotesk",
                                          "fontSize": 20,
                                          "fontWeight": "600"
                                        },
                                        {
                                          "type": "text",
                                          "id": "Vw9AP",
                                          "name": "paragraph",
                                          "fill": "#444444",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "The document calls for an API-first architecture that can support future mobile apps, scalable backend services, PostgreSQL plus Redis, cloud hosting, strong compliance and security controls, and integrations including Google Maps Platform, Stripe Connect, SendGrid, Cloudflare, Mixpanel, AWS S3, Algolia, and OneSignal.",
                                          "lineHeight": 1.6,
                                          "fontFamily": "Inter",
                                          "fontSize": 13,
                                          "fontWeight": "normal"
                                        }
                                      ]
                                    }
                                  ]
                                }
                              ]
                            }
                          ]
                        },
