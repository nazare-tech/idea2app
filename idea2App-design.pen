                                          "name": "exportBtn",
                                          "fill": "#0A0A0A",
                                          "gap": 8,
                                          "padding": [
                                            10,
                                            18
                                          ],
                                          "alignItems": "center",
                                          "children": [
                                            {
                                              "type": "text",
                                              "id": "NMHSj",
                                              "name": "exportTxt",
                                              "fill": "#FFFFFF",
                                              "content": "Export Report",
                                              "fontFamily": "Space Grotesk",
                                              "fontSize": 13,
                                              "fontWeight": "500"
                                            }
                                          ]
