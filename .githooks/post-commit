#!/bin/sh
# Post-commit: synchronously review each code commit with the opposite agent
# CLI, then print a loud notice when the +1000-line thermonuclear sweep is due.
# Review outages cannot undo an existing commit, so the runner records the
# unreviewed SHA under .git/agent-reviews; the active workflow continues but
# must disclose the review gap. Docs-only commits do not spend reviewer tokens.
if ! scripts/post-commit-review.sh HEAD; then
  echo "post-commit: cross-model review failed; this commit is NOT REVIEWED. See .git/agent-reviews/." >&2
fi

# No stderr silencing: a broken sweep marker must stay visible, or the +1000
# sweep trigger dies silently for manual commits.
node scripts/sweep-check.mjs --notify || true
exit 0
