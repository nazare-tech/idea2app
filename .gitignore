# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# npm cache
.npm-cache
.playwright-cli/
.playwright-mcp/
.dmux/
.claude/worktrees/
output/
supabase/.temp/

# local design exports
/design/idea2App-design.json

# local research and generated artifact exports
/local-artifacts/
/pi-session-*.json
/pi-session-*.txt

# Stitch test fixture (contains short-lived download URLs)
src/lib/stitch/test-fixture.json

# local screenshots and temp directories
/*.png
/design/*.png
/tmp/

# build, lint, and tooling artifacts (regenerable; do not track)
/build.log
/lint_final.txt
/*.pdf
/rebrand-preview.html
/tmp-projects-empty-state.html
.codex-artifacts/

# Design tooling source — relocated to its own repo (kept on disk, not tracked)
/Design System/
/assets/logos/

