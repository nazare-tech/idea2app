{
  "name": "makercompass",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22 <23 || >=24 <25"
  },
  "scripts": {
    "dev": "next dev .",
    "build": "next build && node ./scripts/guard-webpack-chunky.mjs",
    "start": "next start",
    "lint": "eslint",
    "test": "node --import tsx --test 'src/**/*.test.ts' 'src/**/*.test.tsx'",
    "typecheck": "tsc --noEmit",
    "guard:chunky": "node ./scripts/guard-webpack-chunky.mjs",
    "guard:chunky:dev": "CHECK_DEV_VENDOR=1 node ./scripts/guard-webpack-chunky.mjs",
    "prepare": "git config core.hooksPath .githooks || exit 0",
    "sweep:check": "node ./scripts/sweep-check.mjs",
    "e2e": "playwright test",
    "e2e:paid": "E2E_PAID_FLOWS=1 playwright test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@json-render/core": "^0.11.0",
    "@json-render/react": "^0.11.0",
    "@json-render/shadcn": "^0.11.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10.58.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.91.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "beautiful-mermaid": "^1.1.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.11",
    "img-fx": "^0.3.1",
    "lucide-react": "^0.563.0",
    "next": "^16.2.9",
    "openai": "^6.16.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "remark-gfm": "^4.0.1",
    "stripe": "^20.2.0",
    "tailwind-merge": "^3.4.0",
    "three": "^0.184.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.9",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "^8.5.15"
  }
}
