                      "gap": 18,
                      "padding": 32,
                      "children": [
                        {
                          "type": "text",
                          "id": "BtYsL",
                          "name": "mvpTitle",
                          "fill": "#0A0A0A",
                          "content": "MVP Plan",
                          "fontFamily": "Space Grotesk",
                          "fontSize": 34,
                          "fontWeight": "700"
                        },
                        {
                          "type": "text",
                          "id": "myU81",
                          "name": "mvpSub",
                          "fill": "#666666",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "# Minimum Viable Product Plan\n\nThis document is rendered as one continuous markdown page in code, centered inside the shared content card with no modular section tiles.",
                          "lineHeight": 1.8,
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "YAPPC",
                          "name": "mvpBodyA",
                          "fill": "#444444",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "## Scope\nThe MVP should focus on episode ingestion, transcript parsing, semantic skip detection, manual review, and playback preview. Everything else should be treated as a follow-on capability until the core workflow proves retention and trust.",
                          "lineHeight": 1.8,
                          "fontFamily": "Inter",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "RcSzR",
                          "name": "mvpBodyB",
                          "fill": "#444444",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "## Milestones\n1. Transcript ingestion and segmentation\n2. Semantic skip scoring and human review\n3. Playback preview and export\n4. Analytics on minutes saved and confidence\n5. Limited founder-led beta with qualitative feedback",
                          "lineHeight": 1.8,
                          "fontFamily": "Inter",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "qfNEE",
                          "name": "mvpBodyC",
                          "fill": "#444444",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "## Non-Goals\n- Broad podcast platform expansion\n- Heavy social or sharing workflows\n- Enterprise procurement and compliance depth\n- Multi-surface design system work before core retention is proven",
                          "lineHeight": 1.8,
                          "fontFamily": "Inter",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "8i7ZV",
                          "name": "mvpBodyD",
                          "fill": "#444444",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "## Exit Criteria\nThe MVP is ready when users can ingest an episode, review detected segments, preview a cleaned result, and report clear time savings without confusion about how the automation works.",
                          "lineHeight": 1.8,
                          "fontFamily": "Inter",
                          "fontSize": 13,
                          "fontWeight": "normal"
