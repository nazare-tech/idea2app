                                    },
                                    {
                                      "type": "frame",
                                      "id": "eT2l8",
                                      "name": "Header Actions",
                                      "gap": 12,
                                      "alignItems": "center",
                                      "children": [
                                        {
                                          "type": "frame",
                                          "id": "PTP1U",
                                          "name": "exportBtn",
                                          "fill": "#0A0A0A",
                                          "gap": 8,
                                          "padding": [
                                            10,
                                            18
                                          ],
                                          "alignItems": "center",
                                          "children": [
                                            {
                                              "type": "text",
                                              "id": "17ISW",
                                              "name": "exportTxt",
                                              "fill": "#FFFFFF",
                                              "content": "Export Report",
                                              "fontFamily": "Space Grotesk",
                                              "fontSize": 13,
                                              "fontWeight": "500"
