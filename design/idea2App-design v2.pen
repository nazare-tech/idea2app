                            {
                              "type": "frame",
                              "id": "rpIKF",
                              "name": "prdBodyA rendered markdown",
                              "width": "fill_container",
                              "layout": "vertical",
                              "gap": 24,
                              "children": [
                                {
                                  "type": "text",
                                  "id": "wbWC3",
                                  "name": "h1 MVP Plan LocalLens",
                                  "fill": "#0A0A0A",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "MVP Plan: LocalLens",
                                  "lineHeight": 1.05,
                                  "fontFamily": "Space Grotesk",
                                  "fontSize": 34,
                                  "fontWeight": "700"
                                },
                                {
                                  "type": "frame",
                                  "id": "JFepM",
                                  "name": "document metadata",
                                  "width": "fill_container",
                                  "fill": "#FAFAFA",
                                  "stroke": {
                                    "thickness": 1,
                                    "fill": "#E5E5E5"
                                  },
                                  "layout": "vertical",
                                  "gap": 6,
                                  "padding": [
                                    14,
