                                      "gap": 10,
                                      "children": [
                                        {
                                          "type": "text",
                                          "id": "E1BmC",
                                          "name": "h3 Prioritization",
                                          "fill": "#0A0A0A",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "4.3 Prioritization",
                                          "lineHeight": 1.2,
                                          "fontFamily": "Space Grotesk",
                                          "fontSize": 20,
                                          "fontWeight": "600"
                                        },
                                        {
                                          "type": "text",
                                          "id": "2Forg",
                                          "name": "priority P0",
                                          "fill": "#444444",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "Must-Have (P0): user registration, curator verification, core itinerary generation, payment processing, recommendation submission, Google Maps integration, responsive web UI, and core search and filtering.",
                                          "lineHeight": 1.6,
                                          "fontFamily": "Inter",
                                          "fontSize": 13,
                                          "fontWeight": "normal"
                                        },
                                        {
                                          "type": "text",
                                          "id": "YzCi8",
                                          "name": "priority P1",
                                          "fill": "#444444",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "Should-Have (P1): advanced personalization, messaging, community validation, offline downloads, cultural context, revenue-share dashboards, push notifications, and social sharing.",
                                          "lineHeight": 1.6,
                                          "fontFamily": "Inter",
                                          "fontSize": 13,
                                          "fontWeight": "normal"
                                        },
                                        {
                                          "type": "text",
                                          "id": "F9sz6",
                                          "name": "priority P2",
                                          "fill": "#444444",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "Nice-to-Have (P2): native mobile apps, AI recommendations, booking integrations, group planning, loyalty programs, curator certification, localization, and AR discovery.",
                                          "lineHeight": 1.6,
                                          "fontFamily": "Inter",
                                          "fontSize": 13,
                                          "fontWeight": "normal"
                                        }
                                      ]
                                    },
                                    {
                                      "type": "frame",
                                      "id": "cWCjQ",
                                      "name": "4.4 UI/UX Design Specifications",
                                      "width": "fill_container",
                                      "layout": "vertical",
                                      "gap": 10,
                                      "children": [
                                        {
                                          "type": "text",
                                          "id": "sxLlg",
                                          "name": "h3 UI UX",
                                          "fill": "#0A0A0A",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "4.4 UI/UX Design Specifications",
                                          "lineHeight": 1.2,
                                          "fontFamily": "Space Grotesk",
                                          "fontSize": 20,
                                          "fontWeight": "600"
                                        },
                                        {
                                          "type": "text",
                                          "id": "qqfRt",
                                          "name": "paragraph",
                                          "fill": "#444444",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "The PRD defines four main flows: onboarding, itinerary discovery, curator journey, and trip execution. Interface guidance is map-first, mobile-friendly, progressively disclosed, visually authentic, and trust-signal heavy. Accessibility requirements include screen-reader support, high contrast, text scaling to 200%, voice navigation support, and offline-friendly behavior.",
                                          "lineHeight": 1.6,
                                          "fontFamily": "Inter",
                                          "fontSize": 13,
                                          "fontWeight": "normal"
                                        }
                                      ]
                                    },
                                    {
                                      "type": "frame",
                                      "id": "26qan",
                                      "name": "4.5 Technical Requirements",
                                      "width": "fill_container",
                                      "layout": "vertical",
                                      "gap": 10,
                                      "children": [
                                        {
                                          "type": "text",
                                          "id": "8vh0z",
                                          "name": "h3 Technical Requirements",
                                          "fill": "#0A0A0A",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "4.5 Technical Requirements",
                                          "lineHeight": 1.2,
                                          "fontFamily": "Space Grotesk",
                                          "fontSize": 20,
                                          "fontWeight": "600"
                                        },
                                        {
                                          "type": "text",
                                          "id": "Vw9AP",
                                          "name": "paragraph",
                                          "fill": "#444444",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "The document calls for an API-first architecture that can support future mobile apps, scalable backend services, PostgreSQL plus Redis, cloud hosting, strong compliance and security controls, and integrations including Google Maps Platform, Stripe Connect, SendGrid, Cloudflare, Mixpanel, AWS S3, Algolia, and OneSignal.",
                                          "lineHeight": 1.6,
                                          "fontFamily": "Inter",
                                          "fontSize": 13,
                                          "fontWeight": "normal"
                                        }
                                      ]
                                    }
                                  ]
                                }
                              ]
                            }
                          ]
